# Copia este archivo como .env y rellena los valores.

# ===== Entorno =====
NODE_ENV=development
PORT=3000

# ===== Base de datos =====
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
# Con el docker-compose incluido: usuario=admin pass=admin123 db=mydb puerto=5499
DATABASE_URL="postgresql://admin:admin123@localhost:5499/mydb"

# ===== JWT =====
JWT_SECRET=
QR_JWT_SECRET=

# ===== API externa Divisist =====
# En desarrollo apunta al mock (ufps-mock-api): http://localhost:8000
DIVISIST_API_URL=
DIVISIST_API_KEY=

# ===== API externa Moodle (solo estudiantes de POSGRADO) =====
MOODLE_API_URL=
MOODLE_API_TOKEN=
